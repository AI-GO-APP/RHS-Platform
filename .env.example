# ============================================================
# RHS 平台環境變數
# 
# 🔄 快速切換租戶：只需更換 SLUG 和 API_KEY，rebuild 即連上新租戶
# ============================================================

# ── Vite Build-time 變數（前端會打包進 JS）──
# App Slug：AI GO 應用識別碼（用於 Auth 端點路徑）
VITE_AIGO_APP_SLUG=6d767888869d

# API 基礎路徑（通常不需更改）
VITE_AIGO_API_BASE=https://ai-go.app/api/v1

# App Domain 隔離標籤（用於 custom_data 中的資料隔離）
VITE_APP_DOMAIN=rhs-platform

# ── Nginx Runtime 變數（伺服器端注入，前端不可見）──
# API Key：Open Proxy 的認證金鑰
AIGO_API_KEY=<your-api-key-here>
