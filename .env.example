# ============================================================
# RHS 平台環境變數範本
#
# 🔄 快速切換租戶：修改以下值，或使用 scripts/switch-tenant.sh 自動產生
# 詳見 docs/tenant-integration-guide.md
# ============================================================

# ── 前端公開變數（VITE_ 前綴，打包進 JS）──
VITE_AIGO_API_BASE=https://ai-go.app/api/v1
VITE_AIGO_APP_SLUG=
VITE_APP_DOMAIN=rhs-platform

# ── 伺服器端腳本專用（不暴露於前端）──
AIGO_API_KEY=
AIGO_BUILDER_EMAIL=
AIGO_BUILDER_PASSWORD=
